# ====================
# CONFIGURAÇÃO DE AMBIENTE (EXEMPLO)
# Copie este arquivo para .env.local e preencha os valores
# ====================

VITE_ENV=development
VITE_DEBUG=true

# --- API BACKEND ---
# Use 'true' para desenvolvimento local (contra mock/localhost)
# Use 'false' para produção (contra servidor definitivo)
VITE_API_USE_MOCK=true
VITE_API_LOCAL_URL=http://localhost:3001
VITE_API_PRODUCTION_URL=https://api-servidor-producao.com

# --- CLOUDINARY ---
VITE_CLOUDINARY_CLOUD_NAME=seu_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=seu_upload_preset
VITE_CLOUDINARY_API_URL=https://api.cloudinary.com/v1_1

# --- SERVIÇOS EXTERNOS ---
VITE_PLACEHOLDER_IMAGE_URL=https://images.unsplash.com/photo-1540518614846-7eded433c457?q=80&w=1200
VITE_WHATSAPP_CONTACT_NUMBER=554799999999

# --- ARMAZENAMENTO ---
VITE_TOKEN_STORAGE_KEY=hub-token

# --- CACHE E TIMEOUTS (ms) ---
VITE_QUERY_STALE_TIME=10000
VITE_FAVORITES_STALE_TIME=60000

# --- PERFORMANCE ---
VITE_DEBOUNCE_DELAY=600
